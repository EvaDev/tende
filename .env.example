# RPC endpoints
RPC_URL_MAINNET=
RPC_URL_SEPOLIA=

# Etherscan verification
ETHERSCAN_API_KEY=

# Pimlico paymaster (gas sponsorship — no contract deployed; backend calls pm_sponsorUserOperation)
PIMLICO_API_KEY=

# ── 1Remit deploy config ──────────────────────────────────────────────────────

# MetaMask EOA that holds DEFAULT_ADMIN_ROLE on all three contracts
DEPLOYER_ADMIN_ADDRESS=
DEPLOYER_ADMIN_PRIVATE_KEY=

# Backend hot-wallet: holds ADMIN_EXECUTOR_ROLE, MINTER_ROLE, and Consumer roles
# Generate with: cast wallet new
BACKEND_SIGNER_ADDRESS=
BACKEND_SIGNER_PRIVATE_KEY=

# Initial TTZA / TTZW supply minted to DEPLOYER_ADMIN_ADDRESS on deploy (2-decimal units; 100000 = R1,000.00)
INITIAL_SUPPLY=0

# ── Network-specific external token addresses ────────────────────────────────

# ZA Reserve ZARP token (backs keccak256("ZAR") currency in Vault)
# Sepolia: deploy a mock ERC20 for testing; mainnet: official ZARP contract
ZARP_TOKEN_ADDRESS=

# ZA Reserve ZARU token (second ZAR backing token; lower priority than ZARP)
ZARU_TOKEN_ADDRESS=

# USDC — registered as keccak256("USDC") to match Vault.USDC_CODE
# Mainnet:  0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# Sepolia:  deploy a mock USDC or use Circle's testnet faucet
USDC_ADDRESS=

# Uniswap V3 SwapRouter02
# Mainnet + Sepolia:  0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
SWAP_ROUTER_ADDRESS=

# Safe v1.4.1 CompatibilityFallbackHandler (adds ERC-1271 signature support to proxies)
# Same address on all chains — verify at https://safe.global/deployments before use
# Pass address(0) to skip fallback handler (ERC-1271 will not be available)
SAFE_FALLBACK_HANDLER_ADDRESS=
