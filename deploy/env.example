# Copy to deploy/env and fill in secrets:
#   cp deploy/env.example deploy/env
#
# All hostnames below use DOMAIN as the registrable suffix for WebAuthn RP_ID.

# ── Hostnames (Cloudflare tunnel routes) ─────────────────────────────────────
DOMAIN=imali.app
TUNNEL_NAME=imali-mac-mini

# Absolute path to this repo on the Mac Mini
IMALI_ROOT=/Users/$(whoami)/eth

# Local reverse proxy port (cloudflared forwards here; TLS at Cloudflare edge)
CADDY_PORT=8080

# ── Postgres ─────────────────────────────────────────────────────────────────
PG_USER=imali
PG_PASSWORD=change-me
PG_DATABASE=imali
PG_HOST=localhost
PG_PORT=5432

# Composed automatically by deploy/link-env.sh and deploy/migrate-db.sh
# DATABASE_URL=postgresql://imali:change-me@localhost:5432/imali

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
JWT_SECRET=generate-with-openssl-rand-hex-32
CHAIN_ID=11155111

RPC_URL_MAINNET=
RPC_URL_SEPOLIA=

# CORS / WebAuthn / idOS — auto-derived from DOMAIN by deploy/link-env.sh
# CORS_ORIGINS=https://app.imali.app,https://admin.imali.app,https://merchant.imali.app
# WEBAUTHN_RP_ID=imali.app
# WEBAUTHN_ORIGIN=https://app.imali.app,https://merchant.imali.app
# IDOS_ISSUER_URI=https://api.imali.app/idos
WEBAUTHN_RP_NAME=iMali

# ── Safe / Pimlico / backend signer (required) ───────────────────────────────
SAFE_SINGLETON_ADDRESS=
SAFE_PROXY_FACTORY_ADDRESS=
SAFE_WEBAUTHN_SIGNER_FACTORY_ADDRESS=
SAFE_FALLBACK_HANDLER_ADDRESS=
SAFE_P256_VERIFIER_ADDRESS=0x445a0683e494ea0c5AF3E83c5159fBE47Cf9e765

PIMLICO_API_KEY=
PIMLICO_BUNDLER_URL=
PIMLICO_SPONSORSHIP_POLICY_ID=
PIMLICO_WEBHOOK_SECRET=

BACKEND_SIGNER_PRIVATE_KEY=

# ── Contracts (after forge deploy) ───────────────────────────────────────────
CONSUMER_CONTRACT_ADDRESS=
VAULT_CONTRACT_ADDRESS=
TREASURY_TOKEN_ZA_ADDRESS=
TREASURY_TOKEN_ZW_ADDRESS=

# ── Admin frontend build-time (export before npm run build in admin/) ─────────
VITE_ALCHEMY_API_KEY=
VITE_WALLETCONNECT_PROJECT_ID=
