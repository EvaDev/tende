# iMali server environment (development or production).
# Production: copy deploy/env.example → deploy/env, fill secrets, then run deploy/link-env.sh

NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://imali:password@localhost:5432/imali
JWT_SECRET=

CHAIN_ID=11155111
RPC_URL_MAINNET=
RPC_URL_SEPOLIA=

# Production only — comma-separated browser origins for credentialed CORS
CORS_ORIGINS=https://app.imali.app,https://admin.imali.app,https://merchant.imali.app

# WebAuthn — dev defaults match consumer:5173 and merchant:5175
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=iMali
WEBAUTHN_ORIGIN=http://localhost:5173,http://localhost:5175

SAFE_SINGLETON_ADDRESS=
SAFE_PROXY_FACTORY_ADDRESS=
SAFE_WEBAUTHN_SIGNER_FACTORY_ADDRESS=
SAFE_FALLBACK_HANDLER_ADDRESS=
SAFE_P256_VERIFIER_ADDRESS=0x445a0683e494ea0c5AF3E83c5159fBE47Cf9e765

PIMLICO_API_KEY=
PIMLICO_BUNDLER_URL=
PIMLICO_SPONSORSHIP_POLICY_ID=
PIMLICO_WEBHOOK_SECRET=

BACKEND_SIGNER_PRIVATE_KEY=

CONSUMER_CONTRACT_ADDRESS=
VAULT_CONTRACT_ADDRESS=
TREASURY_TOKEN_ZA_ADDRESS=
TREASURY_TOKEN_ZW_ADDRESS=
SESSION_TRANSFER_MODULE_ADDRESS=

# Gwei Name Service (https://gwei.domains) — payment tags as subdomains of imali.gwei
# Controller must own the parent NameNFT (same wallet on Sepolia + mainnet for CREATE addresses).
ENS_PARENT_DOMAIN=imali.gwei
ENS_CONTROLLER_ADDRESS=
ENS_CONTROLLER_PRIVATE_KEY=
GNS_CONTRACT_ADDRESS=0x9D51D507BC7264d4fE8Ad1cf7Fe191933A0a81d6

IDOS_MODE=stub
IDOS_ISSUER_URI=http://localhost:3001/idos

INDEXER_ENABLED=true
